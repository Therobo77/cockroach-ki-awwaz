generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Message {
  id         String     @id @default(cuid())
  content    String     @db.VarChar(500)
  authorName String     @db.VarChar(100)
  authorColor String    @db.VarChar(32)
  imageUrl   String?
  createdAt  DateTime   @default(now())
  reactions  Reaction[]

  @@index([createdAt(sort: Desc)])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  emoji     String   @db.VarChar(32)
  count     Int      @default(1)
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji])
  @@index([messageId])
}

model UserDevice {
  id          String   @id
  authorName  String   @db.VarChar(100)
  authorColor String   @db.VarChar(32)
  ipAddress   String   @db.VarChar(64)
  userAgent   String   @db.Text
  os          String?  @db.VarChar(50)
  browser     String?  @db.VarChar(50)
  screenRes   String?  @db.VarChar(20)
  timezone    String?  @db.VarChar(100)
  language    String?  @db.VarChar(20)
  cores       Int      @default(0)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  @@index([lastSeen(sort: Desc)])
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  type        String   @db.VarChar(20)   // 'reaction' | 'mention'
  messageId   String?
  fromName    String   @db.VarChar(100)
  fromColor   String   @db.VarChar(32)
  emoji       String?  @db.VarChar(32)
  excerpt     String?  @db.VarChar(120)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, read])
  @@index([createdAt(sort: Desc)])
}
